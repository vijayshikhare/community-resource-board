# Dependency directories
node_modules/

# Build outputs
build/
dist/
coverage/
.cache/

# Environment files (never commit secrets)
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Backend runtime artifacts
backend/src/uploads/resumes/*
backend/src/uploads/profiles/*
!backend/src/uploads/resumes/.gitkeep
!backend/src/uploads/profiles/.gitkeep

# Frontend artifacts
frontend/build/
